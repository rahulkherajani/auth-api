# Application
NODE_ENV=development
PORT=3000

# Redis
REDIS_URL=redis://localhost:6379

# JWT — secret must be at least 32 characters, enforced by zod
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m

# Refresh token TTL in seconds
# For this case, Refresh token in 7 days
REFRESH_TOKEN_TTL=604800

# Bcrypt, Specifies
BCRYPT_ROUNDS=10

# Rate limiting, Specifies how many requests a single IP can make within a time window
# For this case, 100 requests per 15 minutes per IP
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Account lockout
# For this case, Account lockout for 15 mins after 5 failed attempts 
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION=900
